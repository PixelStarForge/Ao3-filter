{
  "manifest_version": 3,
  "name": "AO3 Filter",
  "version": "2.0.0",
  "description": "Block unwanted fanworks on Archive of Our Own with custom CSS",
  "action": {
    "default_popup": "ao3_css_generator.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://archiveofourown.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://archiveofourown.org/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ao3-filter@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}